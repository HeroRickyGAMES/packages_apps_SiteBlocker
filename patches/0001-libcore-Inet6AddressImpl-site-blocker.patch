+++ b/libcore/ojluni/src/main/java/java/net/Inet6AddressImpl.java
@@ -37,7 +37,14 @@ import dalvik.system.BlockGuard;
 import libcore.io.IoBridge;
 import libcore.io.Libcore;
 
